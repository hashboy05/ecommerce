# Keep the build context small and the image clean.

# Virtual environments — platform-specific (Windows), MUST NOT enter the Linux image
.venv/
venv/
env/

# Python caches
__pycache__/
*.py[cod]

# Local database — the container creates its own fresh copy on startup
instance/
*.db
*.sqlite3

# Tooling / editor / VCS
.vscode/
.claude/
.git/
.gitignore

# Docker files themselves (not needed at runtime)
Dockerfile
.dockerignore
docker-compose.yml

# Docs / OS noise
*.md
.DS_Store
